<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="http://lsst-sal.tuc.noao.edu/schema/SALEventSet.xsl"?>
<SALEventSet xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://lsst-sal.tuc.noao.edu/schema/SALEventSet.xsd">
  <Enumeration>GuiderStatus_Stamp, GuiderStatus_Start, GuiderStatus_Stop, GuiderStatus_Pause, GuiderStatus_Resume</Enumeration>
  <!-- Note: the DAQ publishes one stateMetadata per guide sensor, the following assumes these have been amalgamated into a single event -->
  <SALEvent>
    <Subsystem>Guider</Subsystem>
    <EFDB_Topic>Guider_logevent_stateMetadata</EFDB_Topic>
    <Description>Published once on each guider start/stop/pause/resume/stamp</Description>
    <item>
      <EFDB_Name>status</EFDB_Name>
      <Description>Enumeration with the current guiding status. </Description>
      <!-- Enumeration: GuiderStatus -->
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>seqno</EFDB_Name>
      <Description>DAQ provided sequence number</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>stamp</EFDB_Name>
      <Description>DAQ provided stamp number</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>timestamp</EFDB_Name>
      <Description>DAQ provided timestamp (TAI)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>second</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>obsid</EFDB_Name>
      <Description>OBSID corresponding to this stamp (derived from DAQ comment field)</Description>
      <IDL_Type>string</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>sensors</EFDB_Name>
      <Description>Sensors for which stamps were received (e.g. R00_SG1)</Description>
      <IDL_Type>string</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
  </SALEvent>
  <SALEvent>
    <Subsystem>Guider</Subsystem>
    <EFDB_Topic>Guider_logevent_seriesMetadata</EFDB_Topic>
    <Description>Published once on each start of the guider (corresponding to initGuiders command)</Description>
    <!-- TODO: For now I have omitted information about DAQ firmware/versions etc, and concentrated on essentials -->
    <item>
      <EFDB_Name>roi_common_nrows</EFDB_Name>
      <Description>The number of rows</Description>
      <IDL_Type>long</IDL_Type>
      <Units>pixel</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>roi_common_ncols</EFDB_Name>
      <Description>The number of columns</Description>
      <IDL_Type>long</IDL_Type>
      <Units>pixel</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>roi_common_integration</EFDB_Name>
      <Description>Integration time</Description>
      <IDL_Type>long</IDL_Type>
      <Units>ms</Units>
      <Count>1</Count>
    </item>
    <!-- TODO: For now I have omitted other roi_common items, underCols, overCols, overRows, flushCount, not sure they are needed? -->
    <!-- The following items are all arrays, one per sensor, currently assumes max 8 guide sensors -->
    <item>
      <EFDB_Name>sensor</EFDB_Name>
      <Description>Sensor, e.g. R00_SG0 (: delimited list)</Description>
      <IDL_Type>string</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>segment</EFDB_Name>
      <Description>The segment number within the sensor</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>startrow</EFDB_Name>
      <Description>ROI start row</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>startcol</EFDB_Name>
      <Description>ROI start column</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>splitroi</EFDB_Name>
      <Description>True if the ROI is split across segments</Description>
      <IDL_Type>boolean</IDL_Type>
      <Units>unitless</Units>
      <Count>8</Count>
    </item>
  </SALEvent>
  <SALEvent>
    <Subsystem>Guider</Subsystem>
    <EFDB_Topic>Guider_logevent_perGuiderResults</EFDB_Topic>
    <Description>Results of analysis on each guider</Description>
    <item>
      <EFDB_Name>seqno</EFDB_Name>
      <Description>DAQ provided sequence number</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>stamp</EFDB_Name>
      <Description>DAQ provided stamp number</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>timestamp</EFDB_Name>
      <Description>DAQ provided timestamp (TAI)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>second</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>obsid</EFDB_Name>
      <Description>OBSID corresponding to this stamp (derived from DAQ comment field)</Description>
      <IDL_Type>string</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>sensor</EFDB_Name>
      <Description>Sensor, e.g. R00_SG0 (: delimited list)</Description>
      <IDL_Type>string</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>flux</EFDB_Name>
      <Description>Flux in each sensor</Description>
      <IDL_Type>double</IDL_Type>
      <Units>electron</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>flux_err</EFDB_Name>
      <Description>Error on flux in each sensor</Description>
      <IDL_Type>double</IDL_Type>
      <Units>electron</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>centroid_x</EFDB_Name>
      <Description>Centroid x position in each sensor (in Focal Plane DVCS coordinates)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>centroid_y</EFDB_Name>
      <Description>Centroid y position in each sensor (in Focal Plane DVCS coordinates)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>centroid_x_err</EFDB_Name>
      <Description>Error in Centroid x</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>centroid_y_err</EFDB_Name>
      <Description>Error in Centroid x</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>centroid_dx</EFDB_Name>
      <Description>x offset from first good stamp</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>centroid_dy</EFDB_Name>
      <Description>y offset from first good stamp</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>moment_xx</EFDB_Name>
      <Description>2nd moment xx</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm^2</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>moment_yy</EFDB_Name>
      <Description>2nd moment yy</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm^2</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>moment_xy</EFDB_Name>
      <Description>2nd moment xy</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm^2</Units>
      <Count>8</Count>
    </item>
    <item>
      <EFDB_Name>centroid_fit_quality</EFDB_Name>
      <Description>Flag for good Centroid finding (details TBD)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>unitless</Units>
      <Count>8</Count>
    </item>
  </SALEvent>
  <SALEvent>
    <Subsystem>Guider</Subsystem>
    <EFDB_Topic>Guider_logevent_summaryResults</EFDB_Topic>
    <Description>Results of analysis on all guiders</Description>
    <item>
      <EFDB_Name>seqno</EFDB_Name>
      <Description>DAQ provided sequence number</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>stamp</EFDB_Name>
      <Description>DAQ provided stamp number</Description>
      <IDL_Type>long</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>timestamp</EFDB_Name>
      <Description>DAQ provided timestamp (TAI)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>second</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>obsid</EFDB_Name>
      <Description>OBSID corresponding to this stamp (derived from DAQ comment field)</Description>
      <IDL_Type>string</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>delta_x</EFDB_Name>
      <Description>Centroid Delta X relative to first good Stamp (also in DVCS coordinates)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>delta_y</EFDB_Name>
      <Description>Centroid Delta Y relative to first good Stamp (also in DVCS coordinates)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>mm</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>delta_rotation</EFDB_Name>
      <Description>Delta rotation relative to first good Stamp</Description>
      <IDL_Type>double</IDL_Type>
      <Units>arcsec</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>good_stamps</EFDB_Name>
      <Description>number of good ROIs over the 8 CCDs</Description>
      <IDL_Type>int</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>quality_flag</EFDB_Name>
      <Description>Quality Flag (overall quality of Centroid,Angle information) (details TBD)</Description>
      <IDL_Type>double</IDL_Type>
      <Units>unitless</Units>
      <Count>8</Count>
    </item>
  </SALEvent>
</SALEventSet>
