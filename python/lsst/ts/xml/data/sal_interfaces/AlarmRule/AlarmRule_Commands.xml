<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="http://lsst-sal.tuc.noao.edu/schema/SALCommandSet.xsl"?>
<SALCommandSet xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://lsst-sal.tuc.noao.edu/schema/SALCommandSet.xsd">
  <SALCommand>
    <Subsystem>AlarmRule</Subsystem>
    <EFDB_Topic>AlarmRule_command_configure</EFDB_Topic>
    <Description>Configure an alarm rule.</Description>
    <item>
      <EFDB_Name>config</EFDB_Name>
      <Description>Configuration as yaml text that is parsed to make a keyword argument dict for the alarm rule's configure method.</Description>
      <IDL_Type>string</IDL_Type>
      <IDL_Size>1</IDL_Size>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
  </SALCommand>
  <SALCommand>
    <Subsystem>AlarmRule</Subsystem>
    <EFDB_Topic>AlarmRule_command_run</EFDB_Topic>
    <Description>Run the alarm rule.</Description>
  </SALCommand>
  <SALCommand>
    <Subsystem>AlarmRule</Subsystem>
    <EFDB_Topic>AlarmRule_command_stop</EFDB_Topic>
    <Description>Stop the alarm rule.</Description>
  </SALCommand>
  <SALCommand>
    <Subsystem>AlarmRule</Subsystem>
    <EFDB_Topic>AlarmRule_command_mute</EFDB_Topic>
    <Description>Mute the alarm of the rule.</Description>
    <item>
      <EFDB_Name>alarmName</EFDB_Name>
      <Description>Name of alarm or alarms to mute. Specify a regular expression for multiple alarms.</Description>
      <IDL_Type>string</IDL_Type>
      <IDL_Size>1</IDL_Size>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>muteDuration</EFDB_Name>
      <Description>Duration of mute.</Description>
      <IDL_Type>float</IDL_Type>
      <Units>second</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>severity</EFDB_Name>
      <Description>Severity level being muted. An AlarmSeverity enum.</Description>
      <IDL_Type>int</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>mutedBy</EFDB_Name>
      <Description>User who muted the alarm.</Description>
      <IDL_Type>string</IDL_Type>
      <IDL_Size>1</IDL_Size>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
  </SALCommand>
  <SALCommand>
    <Subsystem>AlarmRule</Subsystem>
    <EFDB_Topic>AlarmRule_command_unmute</EFDB_Topic>
    <Description>Unmute the alarm of the rule.</Description>
    <item>
      <EFDB_Name>alarmName</EFDB_Name>
      <Description>Name of alarm or alarms to unmute. Specify a regular expression for multiple alarms; ".*" to unmute all alarms.</Description>
      <IDL_Type>string</IDL_Type>
      <IDL_Size>1</IDL_Size>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
  </SALCommand>
  <SALCommand>
    <Subsystem>AlarmRule</Subsystem>
    <EFDB_Topic>AlarmRule_command_acknowledge</EFDB_Topic>
    <Description>Acknowledge the alarm of the rule.</Description>
    <item>
      <EFDB_Name>alarmName</EFDB_Name>
      <Description>Name of alarm or alarms to acknowledge. Specify a regular expression for multiple alarms.</Description>
      <IDL_Type>string</IDL_Type>
      <IDL_Size>1</IDL_Size>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>severity</EFDB_Name>
      <Description>Severity level being acknowledged. An AlarmSeverity enum.</Description>
      <IDL_Type>int</IDL_Type>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
    <item>
      <EFDB_Name>acknowledgedBy</EFDB_Name>
      <Description>User who acknowledged the alarm.</Description>
      <IDL_Type>string</IDL_Type>
      <IDL_Size>1</IDL_Size>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
  </SALCommand>
  <SALCommand>
    <Subsystem>AlarmRule</Subsystem>
    <EFDB_Topic>AlarmRule_command_unacknowledge</EFDB_Topic>
    <Description>Unacknowledge the alarm of the rule.</Description>
    <item>
      <EFDB_Name>alarmName</EFDB_Name>
      <Description>Name of alarm or alarms to unacknowledge. Specify a regular expression for multiple alarms.</Description>
      <IDL_Type>string</IDL_Type>
      <IDL_Size>1</IDL_Size>
      <Units>unitless</Units>
      <Count>1</Count>
    </item>
  </SALCommand>
</SALCommandSet>
